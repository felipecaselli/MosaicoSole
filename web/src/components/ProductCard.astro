---
import { urlForImage } from '../utils/sanity';

export interface Props {
  product: {
    _id: string;
    name: string;
    price: number;
    description?: string;
    image?: any;
  };
}

const { product } = Astro.props;
const imageUrl = product.image ? urlForImage(product.image).width(600).height(750).url() : '';
---

<div class="product-card">
  <div class="product-image-wrapper">
    <a href={`/producto/${product._id}`} aria-label={`Ver detalles de ${product.name}`} class="image-link">
      {imageUrl ? (
        <img src={imageUrl} alt={product.name} loading="lazy" class="product-image" />
      ) : (
        <div class="product-image-placeholder">Sin imagen</div>
      )}
    </a>
    
    <div class="product-overlay">
      <button 
        class="add-to-cart-btn font-serif" 
        data-id={product._id}
        data-name={product.name}
        data-image={imageUrl}
      >
        Agregar a la Colección
      </button>
    </div>
  </div>
  
  <div class="product-info">
    <h3 class="product-name font-serif">
      <a href={`/producto/${product._id}`}>{product.name}</a>
    </h3>
    {product.description && <p class="product-desc">{product.description}</p>}
  </div>
</div>

<style>
  .product-card {
    background: transparent;
    border: none;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 16px;
  }

  
  .product-image-wrapper {
    position: relative;
    width: 100%;
    /* Vertical aspect ratio for art feel */
    aspect-ratio: 4 / 5;
    background: var(--color-border);
    overflow: hidden;
    border-radius: var(--radius);
  }

  .image-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .badge-out {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--color-text);
    color: var(--color-surface);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
  }

  /* Overlay that slides up */
  .product-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .product-card:hover .product-overlay {
    opacity: 1;
  }

  .add-to-cart-btn {
    width: 100%;
    background: var(--color-surface);
    color: var(--color-text);
    border: none;
    padding: 14px;
    border-radius: var(--radius);
    font-size: 1.0625rem;
    cursor: pointer;
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), background 0.2s ease, color 0.2s ease;
  }

  .product-card:hover .add-to-cart-btn {
    transform: translateY(0);
  }

  .add-to-cart-btn:not(:disabled):hover {
    background: var(--color-accent);
    color: white;
  }

  .add-to-cart-btn:disabled {
    background: var(--color-border);
    color: var(--color-text-muted);
    cursor: not-allowed;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    padding: 0 4px; /* Slight indent */
  }

  .product-name {
    font-size: 1.375rem;
    color: var(--color-text);
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .product-price {
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .product-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 8px;
    line-height: 1.5;
    /* Optional clamp to keep grid somewhat uniform if we have very long descriptions */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
  }
</style>
