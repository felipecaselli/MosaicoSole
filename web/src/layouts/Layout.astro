---
export interface Props {
  title: string;
  description?: string;
  themeColor?: string;
}

const { title, description = 'MosaicoSole Store', themeColor = '#1C1C1C' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style is:global define:vars={{ themePrimary: themeColor }}>
      :root {
        --color-primary: var(--themePrimary);
        --color-accent: #D4AF37; /* Soft gold */
        --color-bg: #FAFAFA;
        --color-surface: #FFFFFF;
        --color-text: #171717;
        --color-text-muted: #737373;
        --color-border: #EEEEEE;
        --radius: 4px; /* Slightly sharper corners for artistic feel */
        --shadow-sm: 0 2px 8px rgb(0 0 0 / 0.04);
        --shadow: 0 8px 24px rgb(0 0 0 / 0.06);
        --shadow-lg: 0 20px 40px rgb(0 0 0 / 0.1);
      }
      
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4, h5, h6, .font-serif {
        font-family: 'Playfair Display', serif;
        font-weight: 400;
      }

      button {
        font-family: inherit;
        cursor: pointer;
      }

      img {
        max-width: 100%;
        height: auto;
      }
      
      a {
        color: inherit;
        text-decoration: none;
      }

      /* Noise Texture overlay */
      .noise-bg {
        position: relative;
      }
      .noise-bg::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
      }
    </style>
  </head>
  <body class="noise-bg">
    <slot />
  </body>
</html>
